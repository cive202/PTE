# Absolute path to this project on the Docker host.
# Needed so API container can launch MFA containers with correct host bind mounts.
PTE_HOST_PROJECT_ROOT=/absolute/path/to/PTE

# Optional: explicit MFA mount sources on Docker host (override auto mapping)
# PTE_MFA_DOCKER_MOUNT_BASE_DIR=/absolute/path/to/PTE/data/models/mfa
# PTE_MFA_DOCKER_MOUNT_RUNTIME_DIR=/absolute/path/to/PTE/data/processed/mfa_runs
